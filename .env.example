# ── Supabase ──────────────────────────────────────────────────────────
# Your Supabase project URL and service role key.
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key-here

# ── HuggingFace (required for image + text embeddings) ────────────────
# Get your token from: https://huggingface.co/settings/tokens
# A free tier token is sufficient (rate-limited).
HF_TOKEN=hf_your_token_here

# ── Optional Tuning ───────────────────────────────────────────────────
# REQUEST_DELAY=0.5        # seconds between store page requests
# HF_CALL_DELAY=0.5        # seconds between HF API calls
# BATCH_SIZE=50            # rows per batch upsert
# MAX_RETRIES=3            # retry attempts for HTTP/HF/DB calls
# HTTP_TIMEOUT=30          # seconds for HTTP requests
