# ── Supabase ──────────────────────────────────────────────────────────
# Your Supabase project URL and service role key.
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key-here

# ── Optional Tuning ───────────────────────────────────────────────────
# REQUEST_DELAY=0.5        # seconds between store page requests
# BATCH_SIZE=50            # rows per batch upsert
# MAX_RETRIES=3            # retry attempts for HTTP/DB calls
# HTTP_TIMEOUT=30          # seconds for HTTP requests
